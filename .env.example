# Application
APP_NAME=GraphRAG System
ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-here-change-me

# PostgreSQL
POSTGRES_USER=graphrag_user
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=graphrag_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# LLM API Keys (free tier)
GROQ_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_API_KEY=
COHERE_API_KEY=
DASHSCOPE_API_KEY=
ZHIPUAI_API_KEY=
MOONSHOT_API_KEY=
DEEPSEEK_API_KEY=
TOGETHER_API_KEY=

# Embedding (optional)
HF_HOME=./.cache/huggingface

# Document ingestion
DOCUMENT_UPLOAD_DIR=./data/documents
MAX_DOCUMENT_UPLOAD_MB=100

# CORS
ALLOWED_ORIGINS=["*"]
