# Application
APP_NAME=GraphRAG System
ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-here-change-me

# PostgreSQL
POSTGRES_USER=graphrag_user
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=graphrag_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# LLM API Keys (free tier)
GROQ_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_API_KEY=
COHERE_API_KEY=
DASHSCOPE_API_KEY=
ZHIPUAI_API_KEY=
MOONSHOT_API_KEY=
DEEPSEEK_API_KEY=
TOGETHER_API_KEY=

# Embedding (optional)
HF_HOME=./.cache/huggingface
EMBEDDING_PROVIDER=local_hashing
EMBEDDING_MODEL_NAME=local-hashing-v1
EMBEDDING_DIMENSIONS=384

# Document ingestion
DOCUMENT_UPLOAD_DIR=./data/documents
MAX_DOCUMENT_UPLOAD_MB=100

# Vector retrieval
LANCEDB_PATH=./data/lancedb
VECTOR_INDEX_TABLE=document_chunks
VECTOR_DISTANCE_METRIC=cosine
RETRIEVAL_MIN_SCORE=0.0

# End-user chat grounding
CHAT_CONTEXT_TOTAL_CHAR_LIMIT=12000
CHAT_CONTEXT_PER_CHUNK_CHAR_LIMIT=1800
CHAT_CONTEXT_MAX_BLOCKS=8

# CORS
ALLOWED_ORIGINS=["*"]
